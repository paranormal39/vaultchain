# VaultChain Enhanced AI Treasury System Configuration

# =====================
# BIRDEYE API CONFIGURATION
# =====================
# Get your API key from: https://birdeye.so/
BIRDEYE_API_KEY=your_birdeye_api_key_here

# =====================
# CARDANO CONFIGURATION (for Ada Agent)
# =====================
# Blockfrost API key — get yours at https://blockfrost.io/
BLOCKFROST_API_KEY=your_blockfrost_api_key_here
BLOCKFROST_URL=https://cardano-preprod.blockfrost.io/api/v0

# Ada Agent Cardano wallet (optional — will use simulated wallet if not provided)
# Mnemonic seed phrase (24 words)
ADA_WALLET_MNEMONIC=word1 word2 word3 ... word24
CARDANO_NETWORK=testnet

# =====================
# XRPL CONFIGURATION (for Xara Agent)
# =====================
# XRPL network configuration
XRPL_SERVER=wss://xrplcluster.com/
XRPL_NETWORK=mainnet

# Xara Agent XRPL wallet (optional)
XRPL_WALLET_SEED=your_xrpl_wallet_seed
XRPL_WALLET_ADDRESS=your_xrpl_wallet_address

# =====================
# XAHAU HOOKS CONFIGURATION
# =====================
# Xahau is the XRPL amendment that adds smart-contract (Hooks) capability.
# VaultChain uses Hooks for: TREASURY_GUARD, MEMBERSHIP_GATE, FEE_ROUTER
# Leave blank to run in demo/simulation mode.
VITE_XAHAU_SERVER=wss://xahau.network/
VITE_XAHAU_TESTNET=wss://xahau-test.net/
VITE_XAHAU_NETWORK=testnet

# Xahau wallet that holds the DAO Hooks (treasury enforcement account)
# Generate via: node setup-xrpl-wallet.js (and switch server to Xahau)
XAHAU_WALLET_SEED=your_xahau_wallet_seed_here
XAHAU_WALLET_ADDRESS=your_xahau_wallet_address_here

# =====================
# MIDNIGHT CONFIGURATION (for Matthew Agent)
# =====================
# Midnight network configuration
MIDNIGHT_RPC_URL=https://rpc.midnight.network
MIDNIGHT_NETWORK=testnet

# Matthew Agent Midnight wallet (optional)
MIDNIGHT_WALLET_PRIVATE_KEY=your_midnight_private_key

# =====================
# DEXSCREENER API CONFIGURATION
# =====================
# DexScreener API for additional market data
DEXSCREENER_API_KEY=your_dexscreener_api_key
DEXSCREENER_WATCHLIST_ID=your_watchlist_id

# =====================
# COINGECKO API CONFIGURATION
# =====================
# CoinGecko API for price data and market information
COINGECKO_API_KEY=your_coingecko_api_key

# =====================
# SOCIAL SENTIMENT APIS
# =====================
# Twitter API for social sentiment analysis
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret

# Discord webhook for notifications (optional)
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# =====================
# AI AGENT CONFIGURATION
# =====================
# Enable/disable specific agents
ENABLE_MATTHEW_AGENT=true
ENABLE_XARA_AGENT=true
ENABLE_ADA_AGENT=true

# Agent coordination settings
AGENT_COORDINATION_MODE=collaborative
CROSS_CHAIN_ANALYSIS=true
MULTI_AGENT_CONSENSUS=true

# =====================
# TRADING CONFIGURATION
# =====================
# Risk management settings
MAX_POSITION_SIZE_ADA=10000
MAX_POSITION_SIZE_XRP=1000
MAX_POSITION_SIZE_DUST=500

# Risk tolerance (0.01 = 1%, 0.05 = 5%)
RISK_TOLERANCE=0.05
SLIPPAGE_TOLERANCE=0.01

# Trading limits
MAX_DAILY_TRADES=10
MAX_CONCURRENT_POSITIONS=5

# =====================
# MARKET SCANNING CONFIGURATION
# =====================
# Scanning intervals (in milliseconds)
QUICK_SCAN_INTERVAL=30000
DEEP_SCAN_INTERVAL=300000

# Detection thresholds
VOLUME_SPIKE_THRESHOLD=5.0
PRICE_MOVEMENT_THRESHOLD=0.15
SOCIAL_MENTION_THRESHOLD=100

# Market filters
MIN_LIQUIDITY=50000
MIN_VOLUME_24H=100000
MAX_MARKET_CAP=10000000

# =====================
# NOTIFICATION CONFIGURATION
# =====================
# Enable/disable notifications
ENABLE_NOTIFICATIONS=true
NOTIFICATION_CHANNELS=discord,console

# Alert thresholds
HIGH_OPPORTUNITY_THRESHOLD=0.85
URGENT_ALERT_THRESHOLD=0.90

# =====================
# DEVELOPMENT CONFIGURATION
# =====================
# Development mode settings
NODE_ENV=development
DEBUG_MODE=true
VERBOSE_LOGGING=true

# Demo/simulation mode
SIMULATION_MODE=true
USE_REAL_TRADING=false

# =====================
# SECURITY CONFIGURATION
# =====================
# Encryption settings for sensitive data
ENCRYPTION_KEY=your_32_character_encryption_key_here
WALLET_ENCRYPTION=true

# API rate limiting
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=60

# =====================
# DATABASE CONFIGURATION (Optional)
# =====================
# For storing trading history and performance data
DATABASE_URL=sqlite:./vaultchain.db
ENABLE_DATABASE_LOGGING=true

# =====================
# PERFORMANCE MONITORING
# =====================
# Performance tracking settings
TRACK_PERFORMANCE=true
PERFORMANCE_HISTORY_DAYS=30
ENABLE_ANALYTICS=true

# =====================
# EXAMPLE VALUES (DO NOT USE IN PRODUCTION)
# =====================
# These are example values for testing - replace with real credentials

# Example Birdeye API key format
# BIRDEYE_API_KEY=be_1234567890abcdef1234567890abcdef

# Example Blockfrost API key format
# BLOCKFROST_API_KEY=preproduHoAMh5k3Fg5MJZ1Fgm9MCDuZ4ByLPqNI

# Example XRPL wallet seed format
# XRPL_WALLET_SEED=sn3nxiW7v8KXzPzAqzyHXbSSKuQN9

# Example Discord webhook format
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1234567890/abcdefghijklmnopqrstuvwxyz

# =====================
# QUICK SETUP GUIDE
# =====================
# 1. Copy this file to .env
# 2. Get Birdeye API key from https://birdeye.so/
# 3. Configure at least one wallet for testing
# 4. Set SIMULATION_MODE=true for safe testing
# 5. Start with ENABLE_NOTIFICATIONS=false initially
# 6. Gradually enable features as you test
