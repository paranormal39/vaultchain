{
  "name": "vaultchain-dao",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Privacy-first AI-powered treasury management DAO built on Midnight Network",
  "scripts": {
    "start": "npm run dev",
    "start:complete": "node start-complete.js",
    "start:frontend": "npm run dev",
    "dev": "vite",
    "build": "vite build",
    "build:prod": "NODE_ENV=production vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "node evernode/deploy.js deploy",
    "deploy:build": "node evernode/deploy.js build",
    "deploy:status": "node evernode/deploy.js status",
    "deploy:teardown": "node evernode/deploy.js teardown",
    "health": "node evernode/health-check.js",
    "health:json": "node evernode/health-check.js --json --exit-code"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rxjs": "^7.8.1",
    "tailwindcss": "^4.1.12",
    "xrpl": "^4.4.2"
  },
  "devDependencies": {
    "@elizaos/cli": "^1.5.8",
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "vite": "^7.1.5"
  }
